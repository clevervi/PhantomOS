<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PhantomOS.ViewModels"
        xmlns:models="using:PhantomOS.Models"
        xmlns:converters="using:PhantomOS.Converters"
        xmlns:services="using:PhantomOS.Services"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="850"
        x:Class="PhantomOS.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="PhantomOS Industrial"
        Width="1100" Height="850"
        WindowStartupLocation="CenterScreen"
        TransparencyLevelHint="Mica,AcrylicBlur"
        Background="Transparent"
        ExtendClientAreaToDecorationsHint="True">

    <Window.Resources>
        <converters:EqualsConverter x:Key="EqualsConverter" />
        <converters:SeverityToColorConverter x:Key="SeverityToColorConverter" />
        <PageSlide x:Key="TabTransition" Duration="0.4" Orientation="Horizontal" />
    </Window.Resources>

    <Panel>
        <ExperimentalAcrylicBorder IsHitTestVisible="False">
            <ExperimentalAcrylicBorder.Material>
                <ExperimentalAcrylicMaterial BackgroundSource="Digger" TintColor="Black" TintOpacity="0.8" MaterialOpacity="0.9" />
            </ExperimentalAcrylicBorder.Material>
        </ExperimentalAcrylicBorder>

        <Grid ColumnDefinitions="280,*">
            <!-- Sidebar -->
            <Border Grid.Column="0" Background="#11000000" BorderThickness="0,0,1,0" BorderBrush="#11FFFFFF">
                <Grid RowDefinitions="Auto,*,Auto">
                    <StackPanel Grid.Row="0" Margin="30,60,30,40" Spacing="10">
                        <TextBlock Text="👻 PHANTOM OS" FontSize="26" FontWeight="Black" Foreground="#66C2FF" LetterSpacing="2"/>
                    </StackPanel>

                    <ListBox Grid.Row="1" x:Name="MenuBox" Background="Transparent" BorderThickness="0" SelectedIndex="0" Margin="15,0">
                        <ListBoxItem Content="🏠 Dashboard" />
                        <ListBoxItem Content="🚀 Optimización" />
                        <ListBoxItem Content="🛡️ Seguridad" />
                        <ListBoxItem Content="👻 Privacidad" />
                        <ListBoxItem Content="💿 Imagen ISO" />
                        <ListBoxItem Content="🧹 Limpieza" />
                        <ListBoxItem Content="📝 Actividad" />
                    </ListBox>

                    <Border Grid.Row="2" Margin="20" Background="#0AFFFFFF" CornerRadius="12" Padding="15">
                        <TextBlock Text="{Binding SystemSpecsSummary}" FontSize="11" Opacity="0.7" TextWrapping="Wrap"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Content Area -->
            <Grid Grid.Column="1" Margin="40,60,40,40" RowDefinitions="Auto,*">
                <!-- Global Update Banner -->
                <Border Grid.Row="0" IsVisible="{Binding IsUpdateAvailable}" Background="#33FFCC33" CornerRadius="8" Padding="15" Margin="0,0,0,20">
                    <DockPanel>
                        <TextBlock Text="✨" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding NewVersionMessage}" VerticalAlignment="Center" FontWeight="Bold"/>
                        <Button Content="Actualizar" Background="#FFFFCC33" Foreground="Black" FontWeight="Black" HorizontalAlignment="Right" Padding="15,5" CornerRadius="5"/>
                    </DockPanel>
                </Border>

                <TransitioningContentControl Grid.Row="1" Content="{Binding #MenuBox.SelectedIndex}" PageTransition="{StaticResource TabTransition}">
                    <TransitioningContentControl.ContentTemplate>
                        <DataTemplate>
                            <Panel>
                                <!-- VIEW 0: DASHBOARD -->
                                <Border IsVisible="{Binding Converter={StaticResource EqualsConverter}, ConverterParameter=0}">
                                    <Grid RowDefinitions="Auto,Auto,*">
                                        <TextBlock Grid.Row="0" Text="Estado del Sistema" FontSize="28" FontWeight="Black" Foreground="#66C2FF" Margin="0,0,0,20"/>
                                        <Border Grid.Row="1" Background="#11FFFFFF" CornerRadius="20" Padding="40" Margin="0,0,0,20">
                                            <DockPanel>
                                                <StackPanel Orientation="Horizontal" Spacing="20">
                                                    <TextBlock Text="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).TotalHealthScore}" FontSize="72" FontWeight="Black" Foreground="#66C2FF"/>
                                                    <TextBlock Text="%" FontSize="24" VerticalAlignment="Bottom" Margin="0,0,0,15" Opacity="0.3"/>
                                                </StackPanel>
                                                <Button Content="Relanzar Configuración" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ResetWizardCommand}" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.5"/>
                                            </DockPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- VIEW 1: OPTIMIZATION -->
                                <Border IsVisible="{Binding Converter={StaticResource EqualsConverter}, ConverterParameter=1}">
                                    <Grid RowDefinitions="Auto,*,Auto">
                                        <TextBlock Grid.Row="0" Text="Optimización" FontSize="28" FontWeight="Black" Foreground="#66C2FF" Margin="0,0,0,20"/>
                                        <ScrollViewer Grid.Row="1">
                                            <ItemsControl ItemsSource="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).Tweaks}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="models:AtomicTweak">
                                                        <Border Background="#0AFFFFFF" CornerRadius="12" Padding="15" Margin="0,4">
                                                            <CheckBox IsChecked="{Binding IsApplied}" Content="{Binding Name}" />
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                        <Button Grid.Row="2" Content="Aplicar" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ApplyCommand}" HorizontalAlignment="Stretch" Margin="0,20,0,0"/>
                                    </Grid>
                                </Border>

                                <!-- VIEW 2: SECURITY -->
                                <Border IsVisible="{Binding Converter={StaticResource EqualsConverter}, ConverterParameter=2}">
                                    <Grid RowDefinitions="Auto,*">
                                        <TextBlock Grid.Row="0" Text="Seguridad" FontSize="28" FontWeight="Black" Foreground="#00FF99" Margin="0,0,0,20"/>
                                        <ScrollViewer Grid.Row="1">
                                            <ItemsControl ItemsSource="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SecurityFindings}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="models:SecurityFinding">
                                                        <Border Background="#0AFFFFFF" CornerRadius="12" Padding="15" Margin="0,4">
                                                            <TextBlock Text="{Binding Title}" />
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>

                                <!-- VIEW 3: PRIVACY & NETWORK -->
                                <Border IsVisible="{Binding Converter={StaticResource EqualsConverter}, ConverterParameter=3}">
                                    <Grid RowDefinitions="Auto,Auto,Auto,*">
                                        <TextBlock Grid.Row="0" Text="Privacidad &amp; Red" FontSize="28" FontWeight="Black" Foreground="#FFCC33" Margin="0,0,0,20"/>
                                        
                                        <Border Grid.Row="1" Background="#11FFFFFF" CornerRadius="12" Padding="20" Margin="0,0,0,20">
                                            <StackPanel Spacing="15">
                                                <TextBlock Text="LATENCIA GAMING (PRO ANALYZER)" FontSize="12" FontWeight="Black" Opacity="0.4"/>
                                                <ItemsControl ItemsSource="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).GamingLatencies}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="services:NetworkService+PingResult">
                                                            <Border Background="#0AFFFFFF" CornerRadius="8" Padding="12,8" Margin="0,0,10,10" MinWidth="140">
                                                                <DockPanel>
                                                                    <TextBlock Text="{Binding Name}" FontSize="11" Opacity="0.6" VerticalAlignment="Center"/>
                                                                    <TextBlock Text="{Binding Status}" Foreground="{Binding Color}" FontWeight="Black" FontSize="14" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                                </DockPanel>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>

                                        <Border Grid.Row="2" Background="#11FFCC33" CornerRadius="12" Padding="25" Margin="0,0,0,20">
                                            <DockPanel>
                                                <StackPanel Spacing="5">
                                                    <TextBlock Text="Zero Telemetry Shield" FontWeight="Black" FontSize="20" Foreground="#FFCC33"/>
                                                    <TextBlock Text="Bloqueo profundo de red + Servicio DiagTrack." Opacity="0.6"/>
                                                </StackPanel>
                                                <Button Content="Activar Zero" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ApplyZeroTelemetryCommand}" Background="#FFCC33" Foreground="Black" FontWeight="Black" Padding="25,12" CornerRadius="10" HorizontalAlignment="Right"/>
                                            </DockPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- VIEW 4: ISO -->
                                <Border IsVisible="{Binding Converter={StaticResource EqualsConverter}, ConverterParameter=4}">
                                    <TextBlock Text="ISO Modifier" FontSize="28" FontWeight="Black" Foreground="#00CCFF"/>
                                </Border>

                                <!-- VIEW 5: CLEANER -->
                                <Border IsVisible="{Binding Converter={StaticResource EqualsConverter}, ConverterParameter=5}">
                                    <Grid RowDefinitions="Auto,*,Auto">
                                        <TextBlock Grid.Row="0" Text="Deep Cleaner" FontSize="28" FontWeight="Black" Foreground="#FF5555" Margin="0,0,0,20"/>
                                        <ScrollViewer Grid.Row="1" Margin="0,0,0,20">
                                            <ItemsControl ItemsSource="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).CleanupItems}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="services:CleanupService+CleanupItem">
                                                        <Border Background="#0AFFFFFF" CornerRadius="12" Padding="15" Margin="0,4">
                                                            <DockPanel>
                                                                <CheckBox IsChecked="{Binding IsChecked}" VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Margin="15,0" VerticalAlignment="Center"/>
                                                            </DockPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                        <Button Grid.Row="2" Content="Ejecutar Limpieza" Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).RunCleanupCommand}" HorizontalAlignment="Stretch" Background="#FF5555" Padding="20"/>
                                    </Grid>
                                </Border>

                                <!-- VIEW 6: LOGS -->
                                <Border IsVisible="{Binding Converter={StaticResource EqualsConverter}, ConverterParameter=6}">
                                    <Grid RowDefinitions="Auto,*">
                                        <TextBlock Grid.Row="0" Text="Registro de Actividad" FontSize="28" FontWeight="Black" Foreground="#66C2FF" Margin="0,0,0,20"/>
                                        <Border Grid.Row="1" Background="#0AFFFFFF" CornerRadius="12" Padding="10">
                                            <ListBox ItemsSource="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).AppLogs}" Background="Transparent" Foreground="#AAFFFFFF" FontSize="12" FontFamily="Consolas,Monospace"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Panel>
                        </DataTemplate>
                    </TransitioningContentControl.ContentTemplate>
                </TransitioningContentControl>

                <!-- SMART ONBOARDING WIZARD OVERLAY -->
                <Border IsVisible="{Binding ShowWizard}" Background="#CC000000" CornerRadius="20">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="600" Spacing="30">
                        <StackPanel Spacing="10" HorizontalAlignment="Center">
                            <TextBlock Text="BIENVENIDO A PHANTOM OS" FontSize="32" FontWeight="Black" Foreground="#66C2FF" HorizontalAlignment="Center"/>
                            <TextBlock Text="Personaliza tu experiencia de optimización industrial en un clic." Opacity="0.5" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <UniformGrid Columns="3">
                            <Button Command="{Binding ApplyWizardProfileCommand}" CommandParameter="Gaming" Background="Transparent" BorderThickness="0">
                                <Border Background="#11FFFFFF" CornerRadius="15" Padding="25" Margin="10">
                                    <StackPanel Spacing="15">
                                        <TextBlock Text="🎮" FontSize="40" HorizontalAlignment="Center"/>
                                        <TextBlock Text="GAMING" FontWeight="Black" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Prioridad de CPU + Latencia de Red." FontSize="10" Opacity="0.5" TextAlignment="Center" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Button>

                            <Button Command="{Binding ApplyWizardProfileCommand}" CommandParameter="Security" Background="Transparent" BorderThickness="0">
                                <Border Background="#11FFFFFF" CornerRadius="15" Padding="25" Margin="10">
                                    <StackPanel Spacing="15">
                                        <TextBlock Text="🛡️" FontSize="40" HorizontalAlignment="Center"/>
                                        <TextBlock Text="SECURITY" FontWeight="Black" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Blindaje Zero + Privacidad total." FontSize="10" Opacity="0.5" TextAlignment="Center" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Button>

                            <Button Command="{Binding ApplyWizardProfileCommand}" CommandParameter="Balanced" Background="Transparent" BorderThickness="0">
                                <Border Background="#11FFFFFF" CornerRadius="15" Padding="25" Margin="10">
                                    <StackPanel Spacing="15">
                                        <TextBlock Text="⚖️" FontSize="40" HorizontalAlignment="Center"/>
                                        <TextBlock Text="BALANCED" FontWeight="Black" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Recomendado para uso diario pro." FontSize="10" Opacity="0.5" TextAlignment="Center" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </Button>
                        </UniformGrid>
                        
                        <Button Content="Saltar Asistente" Command="{Binding ResetWizardCommand}" Background="Transparent" HorizontalAlignment="Center" FontSize="12" Opacity="0.3"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Panel>
</Window>
